# Dependencies — reinstalled inside the image via npm ci
node_modules/

# Environment files — secrets should never be baked into the image
.env
.env.*
!.env.example

# Git history — not needed at runtime
.git/
.gitignore

# Dev tooling
.vscode/
*.log
npm-debug.log*

# Test files — not needed in production image
tests/
coverage/
jest.config.*

# OS junk
.DS_Store
Thumbs.db

# Docker files themselves
Dockerfile
docker-compose.yml
.dockerignore
