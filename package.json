{
  "name": "multi-tenant-system",
  "version": "1.0.0",
  "description": "Production-grade Multi-Tenant REST API with Node.js, Express, PostgreSQL, and Prisma ORM",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node seed.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2"
  },
  "keywords": [
    "multi-tenant",
    "rest-api",
    "express",
    "prisma",
    "postgresql",
    "rbac"
  ],
  "author": "",
  "license": "ISC"
}
